# Generated text artifacts — regenerate with: pdftotext -layout minutes/*.pdf text/
text/

# Pipeline outputs (regeneratable)
scores/aggregate.json
scores/per_meeting.json
scores/pdfs/

# Snapshots are NOT ignored — they are the delta baseline and cannot be reproduced
# scores/snapshots/

# Python
__pycache__/
*.pyc
*.pyo
.venv/
*.egg-info/

# Source documents — PDFs are binary and often image-based; only JSON extracts are committed
sources/**/*.pdf
sources/**/*.PDF

# Agenda PDF cache — binary, regeneratable via annotated_scraper.py
agendas/pdf_cache/

# Local Claude settings (machine-specific)
.claude/settings.local.json

# macOS
.DS_Store
